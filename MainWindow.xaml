<Window x:Class="ZapAnalyzer.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ZapAnalyzer.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="ZAP | Analizador Espacial 3D" 
        Icon="/Assets/app-icon.png"
        Height="850" Width="1100"
        Background="{StaticResource ZapWhite}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Arial">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Viewport -->
            <RowDefinition Height="40"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Cabecera Institucional con Navegación Externa -->
        <Border Grid.Row="0" Background="{StaticResource ZapBlack}">
            <Grid Margin="30,0">
                <StackPanel Orientation="Horizontal">

                    <!-- Acceso directo a sitio corporativo mediante Logo -->
                    <Button Command="{Binding OpenWebCommand}" ToolTip="Visitar zaparquitectos.com">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image Source="/Assets/logo-blanco.png" 
                                       Height="35" 
                                       VerticalAlignment="Center" 
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Cursor="Hand"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Acciones de Gestión de Datos -->
                    <Button Content="CARGAR JSON" 
                            Command="{Binding LoadJsonCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Height="40" Margin="40,0,0,0"/>

                    <Button Content="DESCARGAR RESULTADOS" 
                            Command="{Binding SaveResultsCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Height="40" Margin="15,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Área de Visualización de Resultados -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40">
                <TextBlock Text="ANÁLISIS DE OBJETOS" Foreground="{StaticResource ZapTextBlack}" FontSize="24" FontWeight="SemiBold" Margin="10,0,0,20"/>

                <!-- Dashboard de Métricas -->
                <UniformGrid Columns="3">
                    <Border Style="{StaticResource DataCard}">
                        <StackPanel>
                            <TextBlock Text="TOTAL PROCESADOS" Foreground="{StaticResource ZapTextGrey}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Summary.TotalProcessed, FallbackValue=0}" FontSize="36" FontWeight="Light" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource DataCard}">
                        <StackPanel>
                            <TextBlock Text="OBJETOS VÁLIDOS" Foreground="{StaticResource ZapTextGrey}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Summary.ValidCount, FallbackValue=0}" FontSize="36" FontWeight="Light" Foreground="#2E7D32" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource DataCard}">
                        <StackPanel>
                            <TextBlock Text="INTERSECCIONES" Foreground="{StaticResource ZapTextGrey}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Summary.IntersectionsCount, FallbackValue=0}" FontSize="36" FontWeight="Light" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource DataCard}">
                        <StackPanel>
                            <TextBlock Text="CONTENCIONES" Foreground="{StaticResource ZapTextGrey}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Summary.ContainmentCount, FallbackValue=0}" FontSize="36" FontWeight="Light" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource DataCard}">
                        <StackPanel>
                            <TextBlock Text="OBJETOS AISLADOS" Foreground="{StaticResource ZapTextGrey}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Summary.IsolatedObjects.Count, FallbackValue=0}" FontSize="36" FontWeight="Light" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource DataCard}">
                        <StackPanel>
                            <TextBlock Text="ERRORES TÉCNICOS" Foreground="{StaticResource ZapTextGrey}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Summary.InvalidCount, FallbackValue=0}" FontSize="36" FontWeight="Light" Foreground="#C62828" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Listado de Entidades Aisladas -->
                <TextBlock Text="OBJETOS AISLADOS DETECTADOS" Foreground="{StaticResource ZapTextBlack}" FontSize="18" FontWeight="SemiBold" Margin="10,30,0,10" 
                           Visibility="{Binding Summary.IsolatedObjects.Count, Converter={StaticResource IntToVisibilityConverter}, FallbackValue=Collapsed}"/>
                <ItemsControl ItemsSource="{Binding Summary.IsolatedObjects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F0F0F0" CornerRadius="15" Padding="12,5" Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ID:" FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding Id}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Panel de Auditoría y Validación Técnica -->
                <TextBlock Text="DETALLES DE VALIDACIÓN (Click para inspeccionar)" Foreground="{StaticResource ZapTextBlack}" FontSize="18" FontWeight="SemiBold" Margin="10,30,0,10" 
                           Visibility="{Binding Summary.InvalidCount, Converter={StaticResource IntToVisibilityConverter}, FallbackValue=Collapsed}"/>

                <ItemsControl ItemsSource="{Binding Summary.ValidationDetails}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Background="White" Margin="10,4" Padding="10" 
                                      Visibility="{Binding IsValid, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal" Margin="5,0">
                                        <TextBlock Text="Objeto " FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#C62828"/>
                                        <TextBlock Text="{Binding Identifier}" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center" Foreground="#C62828"/>
                                        <Border BorderBrush="#DDD" BorderThickness="1,0,0,0" Height="14" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FormattedErrors}" Foreground="#666" FontSize="12" FontStyle="Italic" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Expander.Header>

                                <Border Background="#F9F9F7" BorderBrush="#E9E9E7" BorderThickness="1" CornerRadius="4" Margin="30,10,10,10" Padding="20">
                                    <StackPanel>
                                        <!-- Notificación de error estructural (Fallback) -->
                                        <TextBlock Text="{Binding TechnicalDetail}" Foreground="#C62828" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <Trigger Property="Text" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Visor de Trazabilidad JSON con resaltado de líneas críticas -->
                                        <ItemsControl ItemsSource="{Binding JsonDisplayLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Border Background="#15C62828">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <TextBlock Text="{Binding Text}" FontFamily="Consolas" FontSize="13" Margin="5,1">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#777777"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Barra de Estado de Aplicación -->
        <Border Grid.Row="2" Background="{StaticResource ZapGrey}" BorderBrush="{StaticResource ZapTextGrey}" BorderThickness="0,1,0,0">
            <StatusBar Background="Transparent" Margin="20,0">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource ZapTextBlack}" FontSize="11"/>
                </StatusBarItem>
            </StatusBar>
        </Border>
    </Grid>
</Window>